# Hashed, content-addressed assets never change — cache them aggressively.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML routes must always be re-fetched so new hashed asset URLs are picked up
# (replaces the no-store behavior the old Go server set by hand). Covers the
# pre-rendered per-route pages emitted by the SEO plugin.
/index.html
  Cache-Control: no-store, must-revalidate
/
  Cache-Control: no-store, must-revalidate
/faq
  Cache-Control: no-store, must-revalidate
/policy
  Cache-Control: no-store, must-revalidate

# Markdown Return: AI-readable mirrors of the doc pages. Served as markdown,
# kept out of the search index, and pointed back at the canonical HTML route.
/faq.md
  Content-Type: text/markdown; charset=utf-8
  X-Robots-Tag: noindex
  Link: <https://qr.takumi-tokunaga.com/faq>; rel="canonical"
/policy.md
  Content-Type: text/markdown; charset=utf-8
  X-Robots-Tag: noindex
  Link: <https://qr.takumi-tokunaga.com/policy>; rel="canonical"

# Social/share image and favicon — not content-hashed, so cache for a week.
/og/*
  Cache-Control: public, max-age=604800
/favicon.svg
  Cache-Control: public, max-age=604800

# Security headers. The app handles Wi-Fi passwords purely in the browser and
# makes no network calls, so the policy can be strict.
# style-src allows 'unsafe-inline' because MUI/Emotion injects runtime <style> tags.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' https://pagead2.googlesyndication.com; connect-src 'self' https:; frame-src https://googleads.g.doubleclick.net https://tpc.googlesyndication.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
